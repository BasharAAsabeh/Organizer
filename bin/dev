#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
BACKEND_HOST="${BACKEND_HOST:-0.0.0.0}"
BACKEND_PORT="${BACKEND_PORT:-3001}"
FRONTEND_HOST="${FRONTEND_HOST:-0.0.0.0}"
FRONTEND_PORT="${FRONTEND_PORT:-5173}"
PID_FILE="$ROOT_DIR/tmp/dev.pid"

backend_pid=""
frontend_pid=""

port_in_use() {
  local port="$1"

  if command -v ss >/dev/null 2>&1; then
    ss -ltn "sport = :${port}" | grep -q ":${port}"
  elif command -v lsof >/dev/null 2>&1; then
    lsof -iTCP:"${port}" -sTCP:LISTEN -t >/dev/null
  else
    return 1
  fi
}

cleanup() {
  trap - INT TERM EXIT

  if [[ -n "$backend_pid" ]]; then
    kill "$backend_pid" 2>/dev/null || true
  fi

  if [[ -n "$frontend_pid" ]]; then
    kill "$frontend_pid" 2>/dev/null || true
  fi

  wait 2>/dev/null || true
  rm -f "$PID_FILE"
}

trap cleanup INT TERM EXIT

if port_in_use "$BACKEND_PORT"; then
  echo "Port ${BACKEND_PORT} is already in use. Stop the existing process first:"
  echo "  fuser -k ${BACKEND_PORT}/tcp"
  exit 1
fi

if port_in_use "$FRONTEND_PORT"; then
  echo "Port ${FRONTEND_PORT} is already in use. Stop the existing process first:"
  echo "  fuser -k ${FRONTEND_PORT}/tcp"
  exit 1
fi

echo "Starting Rails API on http://${BACKEND_HOST}:${BACKEND_PORT}"
(
  cd "$ROOT_DIR/backend"
  ./bin/rails server -b "$BACKEND_HOST" -p "$BACKEND_PORT"
) &
backend_pid=$!

echo "Starting Vite frontend on http://${FRONTEND_HOST}:${FRONTEND_PORT}"
(
  cd "$ROOT_DIR/frontend"
  npm run dev -- --host "$FRONTEND_HOST" --port "$FRONTEND_PORT" --strictPort
) &
frontend_pid=$!

mkdir -p "$(dirname "$PID_FILE")"
printf "%s\n%s\n%s\n" "$$" "$backend_pid" "$frontend_pid" > "$PID_FILE"

while kill -0 "$backend_pid" 2>/dev/null && kill -0 "$frontend_pid" 2>/dev/null; do
  sleep 1
done

cleanup
exit 1
